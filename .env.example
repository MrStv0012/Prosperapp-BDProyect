PORT=3000

# Debe coincidir con las credenciales que definiste en docker-compose.yml
# (POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prosperapp

# Genera una clave propia con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria
